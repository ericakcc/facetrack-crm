# FaceTrack CRM — environment variables
# Copy this file to `.env` (already gitignored) and fill in your keys.
# Restart Streamlit after editing.

# -------------------------------------------------------------------------
# LLM explainer backends
# -------------------------------------------------------------------------
# Set ONE of the following (or both — see LLM_BACKEND below).
# If neither is set, the app uses the offline MockExplainer.

ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Override backend selection. Leave blank for auto (Anthropic preferred over Gemini).
# Valid values: anthropic | gemini
LLM_BACKEND=
